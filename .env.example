# Copy this file to .env and replace with your real values.
# Do not commit .env or share it.

# ── Groq API Key Pool (multi-key fallback) ──────────────────────────────────
# Add up to 10 keys. The engine will rotate to the next key on rate-limit/error.
GROQ_API_KEY_1=your_groq_api_key_here
GROQ_API_KEY_2=your_second_groq_api_key_here
GROQ_API_KEY_3=your_third_groq_api_key_here

# If you only have one key, set GROQ_API_KEY (legacy fallback)
# GROQ_API_KEY=your_groq_api_key_here

# ── Model ───────────────────────────────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile
